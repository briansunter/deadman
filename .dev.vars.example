# Copy to .dev.vars for local development

# REQUIRED - secures all endpoints
AUTH_TOKEN=change-me-to-a-secure-random-token

# Configure at least one complete notification channel.

# Slack incoming webhook URL (Apps > Incoming Webhooks)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Discord webhook URL (Server Settings > Integrations > Webhooks)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Telegram bot token and chat ID (must be set together)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=-1001234567890

# Cloudflare Email Routing (set both if you use email)
# EMAIL_FROM=deadman@yourdomain.com
# EMAIL_TO=alerts@yourdomain.com
